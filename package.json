{
  "name": "app-for-web-architectures",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "install-all": "npm install"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
